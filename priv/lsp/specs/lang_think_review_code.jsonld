{
  "@context": {
    "lang": "https://lang.nulity.com/schema/v1/",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@id": "lang:lang.think.review_code",
  "@type": "lang:Function",
  "category": "think",
  "description": "AI-powered code review with quality scoring",
  "implementation": {
    "file": "lib/lang/think/ai_engine.ex",
    "priority": "High",
    "status": "implemented"
  },
  "name": "lang.think.review_code",
  "params": {
    "type": "object",
    "properties": {
      "code": { "type": "string", "description": "Inline code snippet to review" },
      "realtime": { "type": "boolean", "description": "Return immediate fast-path result when true" },
      "stream": { "type": "boolean", "description": "Stream incremental review via PubSub when true" }
    }
  }
}
