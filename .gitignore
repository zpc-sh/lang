# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies source to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project refs.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore generated crash dumps from Erlang/OTP.
erl_crash.dump
erl_crash.dump.*

# Ignore database data
/priv/repo/data/

# Ignore static assets generated by Phoenix
/priv/static/assets/

# Ignore node_modules
/node_modules/

# Ignore assets generated by npm
/assets/node_modules/

# Ignore logs
/logs/
*.log

# Editor directories and files
.idea/
.vscode/
*.swp
*.swo
.DS_Store
