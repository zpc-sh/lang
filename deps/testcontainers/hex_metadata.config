{<<"name">>,<<"testcontainers">>}.
{<<"version">>,<<"1.13.3">>}.
{<<"description">>,
 <<"Testcontainers is an Elixir library that supports ExUnit tests, providing lightweight, throwaway instances of common databases, Selenium web browsers, or anything else that can run in a Docker container.">>}.
