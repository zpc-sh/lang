{<<"links">>,
 [{<<"Ash Framework">>,<<"https://ash-hq.org">>},
  {<<"GitHub">>,<<"https://github.com/nocsi/ash_profiler">>}]}.
{<<"name">>,<<"ash_profiler">>}.
{<<"version">>,<<"0.1.0">>}.
{<<"description">>,
 <<"Performance profiling and optimization toolkit for Ash Framework applications.\nAnalyze DSL complexity, identify compilation bottlenecks, and get actionable optimization recommendations.">>}.
{<<"elixir">>,<<"~> 1.15">>}.
{<<"files">>,
 [<<"lib">>,<<"lib/ash_profiler.ex">>,<<"lib/mix">>,<<"lib/mix/tasks">>,
  <<"lib/mix/tasks/ash_profiler.ex">>,
  <<"lib/mix/tasks/debug_compilation.ex">>,
  <<"lib/mix/tasks/ash_profiler_docker.ex">>,<<"lib/ash_profiler">>,
  <<"lib/ash_profiler/container_profiler.ex">>,
  <<"lib/ash_profiler/dsl_profiler.ex">>,
  <<"lib/ash_profiler/container_detector.ex">>,
  <<"lib/ash_profiler/docker_optimizer.ex">>,
  <<"lib/ash_profiler/domain_analyzer.ex">>,<<".formatter.exs">>,
  <<"mix.exs">>,<<"README.md">>,<<"LICENSE">>,<<"CHANGELOG.md">>,
  <<"AGENTS.md">>]}.
{<<"app">>,<<"ash_profiler">>}.
{<<"licenses">>,[<<"MIT">>]}.
{<<"requirements">>,
 [[{<<"name">>,<<"ash">>},
   {<<"app">>,<<"ash">>},
   {<<"optional">>,false},
   {<<"requirement">>,<<"~> 3.0">>},
   {<<"repository">>,<<"hexpm">>}],
  [{<<"name">>,<<"telemetry">>},
   {<<"app">>,<<"telemetry">>},
   {<<"optional">>,false},
   {<<"requirement">>,<<"~> 1.0">>},
   {<<"repository">>,<<"hexpm">>}],
  [{<<"name">>,<<"jason">>},
   {<<"app">>,<<"jason">>},
   {<<"optional">>,false},
   {<<"requirement">>,<<"~> 1.4">>},
   {<<"repository">>,<<"hexpm">>}]]}.
{<<"build_tools">>,[<<"mix">>]}.
