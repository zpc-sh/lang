# LANG Universal Text Intelligence Platform
# Environment Configuration Template
#
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ===== REQUIRED SECRETS (Application will not start without these) =====

# Phoenix Secret Key Base (generate with: mix phx.gen.secret)
SECRET_KEY_BASE=your-secret-key-base-here

# LiveView Signing Salt (generate with: mix phx.gen.secret 32)
LIVE_VIEW_SIGNING_SALT=your-liveview-salt-here

# AshAuthentication Secret (generate with: mix phx.gen.secret 64)
ASH_AUTHENTICATION_SECRET=your-ash-auth-secret-here

# Encryption Key for sensitive data (generate with: :crypto.strong_rand_bytes(32) |> Base.encode64())
ENCRYPTION_KEY=your-encryption-key-here

# ===== DATABASE CONFIGURATION =====

# Option 1: Full Database URL (preferred)
DATABASE_URL=postgres://username:password@localhost:5432/lang_dev

# Option 2: Individual Database Settings (used if DATABASE_URL not set)
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_HOSTNAME=localhost
DB_DATABASE=lang_dev
DB_PORT=5432
DB_POOL_SIZE=10

# ===== APPLICATION CONFIGURATION =====

# Application Host and Port
APP_HOST=localhost
PORT=4000

# LSP Server Port
LSP_PORT=4001

# Redis for Caching
REDIS_URL=redis://localhost:6379/0

# ===== SECURITY CONFIGURATION =====

# Rate Limiting
RATE_LIMITING_ENABLED=true
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10
RATE_LIMIT_CLEANUP_INTERVAL=60000

# CORS Configuration
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# ===== TEXT PROCESSING LIMITS =====

# Maximum content size in bytes (50MB default)
MAX_CONTENT_SIZE=52428800

# Analysis timeout in milliseconds
ANALYSIS_TIMEOUT=30000

# Maximum conversation turns
MAX_CONVERSATION_TURNS=1000

# Maximum timeline states
MAX_TIMELINE_STATES=10000

# ===== TELEMETRY AND LOGGING =====

# Enable telemetry collection
TELEMETRY_ENABLED=true

# Enable Prometheus metrics
PROMETHEUS_ENABLED=false
METRICS_PORT=9090

# Logging configuration
LOG_LEVEL=info
STRUCTURED_LOGGING=false

# ===== EXTERNAL SERVICES (Optional) =====

# AI Services
OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
XAI_API_KEY=your-xai-key-here
GEMINI_API_KEY=your-gemini-key-here

# Email Service
SENDGRID_API_KEY=your-sendgrid-key-here

# Webhooks
WEBHOOK_SECRET=your-webhook-secret-here

# AWS/S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET=your-s3-bucket
S3_REGION=us-east-1

# ===== DEVELOPMENT/TESTING =====

# Enable Phoenix server (for releases)
PHX_SERVER=true

# DNS cluster query (for distributed deployments)
DNS_CLUSTER_QUERY=

# IPv6 support
ECTO_IPV6=false

# ===== QUICK START COMMANDS =====
#
# 1. Generate secrets:
#    mix phx.gen.secret     # For SECRET_KEY_BASE
#    mix phx.gen.secret 32  # For LIVE_VIEW_SIGNING_SALT
#    mix phx.gen.secret 64  # For ASH_AUTHENTICATION_SECRET
#
# 2. Generate encryption key:
#    In IEx: :crypto.strong_rand_bytes(32) |> Base.encode64()
#
# 3. Start services:
#    docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:15
#    docker run -d -p 6379:6379 redis:7-alpine
#
# 4. Setup application:
#    ./lang_init_script.sh
#
# 5. Start development server:
#    mix phx.server
#
# Add to .env.example
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxx

